-- TARGET LOGIC | STRICT WALL CHECK
local function GetBestTarget()
    if IsRagdolled(Humanoid) or not _G.Settings.AimlockEnabled then CurrentTarget = nil; return nil end
    if CurrentTarget then
        local tc = CurrentTarget.Parent; local th = tc and tc:FindFirstChild("Humanoid")
        if th and th.Health > 0 and not IsRagdolled(th) then
            if HasLineOfSight(HumanoidRootPart.Position, CurrentTarget) then return CurrentTarget end
        end
        CurrentTarget = nil
    end
    local best,bestD=nil,math.huge
    for _,d in pairs(_G.Enemies) do
        local c=d.Player.Character; local aim=c and c:FindFirstChild(_G.Settings.AimPart)
        local hrp=c and c:FindFirstChild("HumanoidRootPart"); local hum=c and c:FindFirstChild("Humanoid")
        if IsValidHuman(hum) and aim and HasLineOfSight(HumanoidRootPart.Position, aim) then
            local dist=(Camera.CFrame.Position-aim.Position).Magnitude
            if dist<bestD then bestD=dist; best=aim end
        end
    end
    CurrentTarget=best; return best
end

RunService.RenderStepped:Connect(function()
    if not Character or not HumanoidRootPart then CurrentTarget=nil return end
    local target = GetBestTarget()
    if _G.Settings.AutoZoomEnabled then Camera.FieldOfView = target and _G.Settings.ZoomFOV or _G.Settings.NormalFOV end
    if target then
        local aim=target.Position; local hrp=target.Parent:FindFirstChild("HumanoidRootPart")
        if hrp then aim += hrp.Velocity*(_G.Settings.Prediction/100) end
        aim += Vector3.new(0,_G.Settings.Offset/10,0)
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position,aim), _G.Settings.AimSpeed/100)
    end
end)

