-- ✅ STRICT WALL CHECK ENFORCED EVERYWHERE
local function GetBestTarget()
    if IsRagdolled(Humanoid) or not _G.Settings.AimlockEnabled or not Humanoid or Humanoid.Health <= 0 then
        CurrentTarget = nil; return nil
    end

    if CurrentTarget then
        local targetChar = CurrentTarget.Parent
        local targetHum = targetChar and targetChar:FindFirstChild("Humanoid")
        if targetHum and targetHum.Health > 0 and not IsRagdolled(targetHum) then
            -- ONLY DROP IF: WALL BLOCKED + OFF SCREEN
            if not HasLineOfSight(HumanoidRootPart.Position, CurrentTarget) then
                CurrentTarget = nil
            else
                return CurrentTarget
            end
        else
            CurrentTarget = nil
        end
    end

    local best,bestD=nil,math.huge
    for _,d in pairs(_G.Enemies) do
        local p=d.Player; if not p then continue end
        local c=p.Character; local hum=c and c:FindFirstChild("Humanoid")
        local aimPart = c and c:FindFirstChild(_G.Settings.AimPart)
        local hrp=c and c:FindFirstChild("HumanoidRootPart")
        -- ✅ WALL CHECK REQUIRED TO LOCK NEW TARGET
        if IsValidHuman(hum) and aimPart and hrp and HasLineOfSight(HumanoidRootPart.Position, aimPart) then
            local dist=(Camera.CFrame.Position-aimPart.Position).Magnitude
            if dist<bestD then bestD=dist; best=aimPart end
        end
    end
    CurrentTarget=best; return best
end

local LastShot = 0
local function AutoAirCheck(target)
    if not _G.Settings.AutoAirTrigger or not target then return end
    local char = target.Parent
    local hum = char:FindFirstChild("Humanoid")
    if hum and hum.FloorMaterial == Enum.Material.Air and os.clock() - LastShot > 0.3 then
        task.spawn(function()
            UserInputService:SendKeyEvent(true, Enum.KeyCode.MouseLeftButton, false, game)
            task.wait(0.05)
            UserInputService:SendKeyEvent(false, Enum.KeyCode.MouseLeftButton, false, game)
            LastShot = os.clock()
        end)
    end
end

RunService.RenderStepped:Connect(function()
    if not Character or not HumanoidRootPart then CurrentTarget=nil return end
    local target = GetBestTarget()

    if _G.Settings.AutoZoomEnabled then Camera.FieldOfView = target and _G.Settings.ZoomFOV or _G.Settings.NormalFOV end
    if target then
        AutoAirCheck(target)
        local hrp=target.Parent:FindFirstChild("HumanoidRootPart")
        local aim=target.Position
        if hrp then aim += hrp.Velocity*(_G.Settings.Prediction/100) end
        aim += Vector3.new(0,_G.Settings.Offset/10,0)
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position,aim), _G.Settings.AimSpeed/100)
    end

    for uid,d in pairs(_G.Enemies) do
        local p=d.Player; if not p then RemoveEnemy(uid) continue end
        local c=p.Character; local hum=c and c:FindFirstChild("Humanoid")
        local hrp=c and c:FindFirstChild("HumanoidRootPart")
        if c and IsValidHuman(hum) and hrp then
            d.Glow.Enabled = _G.Settings.ShowNameDist
            d.Tag.Enabled = _G.Settings.ShowNameDist
            if _G.Settings.ShowNameDist then
                d.Glow.Adornee=c; d.Tag.Adornee=hrp
                d.TName.Text=p.DisplayName
                d.TDist.Text=math.floor((HumanoidRootPart.Position-hrp.Position).Magnitude).." studs"
            end
            if d.Skeleton then
                for _,v in pairs(d.Skeleton) do
                    local a = c:FindFirstChild(v.A)
                    local b = c:FindFirstChild(v.B)
                    if a and b then
                        local posA, visA = Camera:WorldToViewportPoint(a.Position)
                        local posB, visB = Camera:WorldToViewportPoint(b.Position)
                        v.Line.Visible = _G.Settings.ShowSkeleton and visA and visB
                        if v.Line.Visible then v.Line.From = Vector2.new(posA.X,posA.Y); v.Line.To = Vector2.new(posB.X,posB.Y) end
                    else v.Line.Visible = false end
                end
            end
        else
            d.Glow.Enabled=false; d.Tag.Enabled=false
            if d.Skeleton then for _,v in pairs(d.Skeleton) do v.Line.Visible=false end end
        end
    end
end)

