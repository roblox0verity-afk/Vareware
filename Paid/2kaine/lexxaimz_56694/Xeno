local function RemoveEnemy(uid)
    local d = _G.Enemies[uid]; if not d then return end
    if d.Glow then d.Glow:Destroy() end; if d.Tag then d.Tag:Destroy() end
    if d.Row then d.Row:Destroy() end; _G.Enemies[uid] = nil
    if CurrentTarget and d.Player and CurrentTarget.Parent == d.Player.Character then CurrentTarget = nil end
end

