local function HasLineOfSight(fromPos, toPart)
    if not fromPos or not toPart then return false end
    local offset = Vector3.new(0, 0.5, 0)
    local res = Workspace:Raycast(fromPos + offset, toPart.Position - (fromPos + offset), RaycastParams)
    return not res or res.Instance:IsDescendantOf(toPart.Parent)
end

local function IsRagdolled(hum)
    if not hum or not hum.Parent then return true end
    local char = hum.Parent
    return hum:GetState() == Enum.HumanoidStateType.Ragdoll or hum.PlatformStand == true
        or char:FindFirstChild("IsRagdoll") and char.IsRagdoll.Value == true or hum.Sit == true
end

local function IsValidHuman(hum)
    if not hum or hum.Health <= 0 then return false end
    if IsRagdolled(hum) then return false end
    return true
end

